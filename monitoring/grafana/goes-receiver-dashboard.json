    {
      "type": "timeseries",
      "title": "Viterbi errors (avg/frame) \u2014 lower is better",
      "description": "Forward-error-correction load. <~400 good lock, rising toward ~2000 = losing signal.",
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 8,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never",
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "rate(viterbi_errors_sum[5m])/rate(viterbi_errors_count[5m])",
          "legendFormat": "viterbi avg",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "viterbi_errors{quantile=\"0.9\"}",
          "legendFormat": "p90",
          "refId": "B"
        }
      ]
    },
