# Copy to setup.env (gitignored) and fill in. Sourced by the deploy scripts.
# ---- Hosts (example LAN; adjust to yours) ----
PI_HOST=10.10.0.9           # Raspberry Pi : RTL-SDR demod (goesrecv)
LXC_HOST=10.10.0.11         # Proxmox LXC  : goesproc + loops + EMWIN alerts + upload
MINIO_HOST=10.10.0.10       # MinIO S3 archive
HA_HOST=10.10.0.5           # Home Assistant
GRAFANA_HOST=172.16.50.146  # Grafana + Prometheus

# ---- Secrets (do NOT commit real values) ----
GOES_S3_SECRET=             # MinIO access key 'goessvc' secret
HA_TOKEN=                   # HA long-lived access token

# ---- Site params ----
GOES_SAT=goes19             # GOES-East (goes18 = GOES-West)
GOES_FREQ=1694100000        # HRIT, Hz (GOES-West = 1686600000)
WFO=KMOB                    # your local NWS office (for alert filtering)
LAT=30.69                   # example: your latitude
LON=-88.04                  # example: your longitude
